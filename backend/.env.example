PORT=3000

# Supabase Configuration (Required for core features)
SUPABASE_URL=https://biqohhlgwgobyvbbwzvq.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Firebase Configuration (Required for core features)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
FIREBASE_APP_ID=your_firebase_app_id_here

# Google Maps API Key (Required for "Nearby Services" feature - hospitals, pharmacies, doctors)
# Get from: https://cloud.google.com/maps-platform
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Pinecone Configuration (Required for MediChat AI Doctor feature)
# Get from: https://www.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=your_pinecone_index_name_here

# GROQ API Key (Required for MediChat AI Doctor feature)
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Optional: override model used by MediChat
GROQ_MODEL=llama-3.1-8b-instant

# Tavily Search API Key (Required for MediChat AI Doctor feature)
# Get from: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# NexHealth API Configuration (Required for "Appointments" feature)
# Get from: https://nexhealth.com
NEXHEALTH_API_KEY=your_nexhealth_api_key_here
NEXHEALTH_SUBDOMAIN=your_nexhealth_subdomain_here
NEXHEALTH_LOCATION_ID=your_nexhealth_location_id_here
